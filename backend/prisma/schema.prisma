// Prisma schema for ShubhHomes CRM - PostgreSQL
// Updated: Added JSONB support for flexible Excel imports

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Core CRM Entities ───────────────────────────────

model Lead {
  id            String    @id @default(cuid())
  name          String
  phone         String
  email         String?
  source        String    @default("Manual") // Website, Meta Ads, JustDial, Excel Import...
  stage         String    @default("New")    // New, Contacted, Visit, Negotiation, Booked, Lost
  budget        Float?
  project       String?
  assignedTo    String?
  createdAt     DateTime  @default(now())
  lastActivity  DateTime  @updatedAt
  tags          String[]  // Hot, Warm, Cold...
  value         Float     @default(0)
  updatedAt     DateTime  @updatedAt

  // ── Flexible storage for extra columns from Excel ──
  customFields  Json?     // {"Locality": "Baner", "Flat Preference": "3BHK", ...}
  importId      String?   // Which import batch this lead came from

  @@index([phone])
  @@index([source])
  @@index([stage])
}

model Unit {
  id          String   @id @default(cuid())
  project     String
  tower       String
  floor       Int
  unitNumber  String
  type        String   // 2BHK, 3BHK...
  area        Float
  status      String   // Available, Hold, Booked, Sold
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Booking {
  id              String   @id @default(cuid())
  leadId          String
  leadName        String
  unitId          String
  unitNumber      String
  project         String
  agreementValue  Float
  bookingDate     DateTime @default(now())
  paymentPlan     String
  status          String   @default("Active") // Active, Cancelled
  createdAt       DateTime @default(now())
}

model Payment {
  id         String    @id @default(cuid())
  bookingId  String
  leadName   String
  amount     Float
  dueDate    DateTime
  paidDate   DateTime?
  status     String    // Pending, Paid, Overdue
  mode       String?
  receiptNo  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String   // RERA, Layout, Template...
  project     String?
  size        String
  uploadedAt  DateTime @default(now())
  url         String?  // For future real storage
}

model Agent {
  id        String   @id @default(cuid())
  name      String
  role      String
  avatar    String
  team      String?
  target    Float
  achieved  Float
  calls     Int      @default(0)
  visits    Int      @default(0)
  bookings  Int      @default(0)
  updatedAt DateTime @updatedAt
}

// ─── Supporting Entities ─────────────────────────────

model Workflow {
  id        String  @id @default(cuid())
  name      String
  trigger   String
  condition String
  action    String
  active    Boolean @default(true)
}

model Campaign {
  id          String  @id @default(cuid())
  platform    String
  name        String
  spend       Float
  impressions Int
  clicks      Int
  leads       Int
  status      String
}

// ─── Excel Import Pipeline ───────────────────────────

model LeadImport {
  id            String          @id @default(cuid())
  fileName      String                              // "justdial_july_leads.xlsx"
  uploadedBy    String          @default("admin")    // User who uploaded
  totalRows     Int                                  // 150
  processedRows Int             @default(0)          // 142
  skippedRows   Int             @default(0)          // 8
  status        String          @default("pending")  // pending → mapping → processing → completed → failed
  columnMapping Json?                                // {"Full Name": "name", "Mobile": "phone", ...}
  headers       String[]                             // ["Full Name", "Phone Number", "Ad Campaign", ...]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  rows          LeadImportRow[]
}

model LeadImportRow {
  id          String      @id @default(cuid())
  importId    String
  import      LeadImport  @relation(fields: [importId], references: [id], onDelete: Cascade)
  rowNumber   Int                               // Excel row number
  rawData     Json                              // {"Full Name": "Rahul Sharma", "Mobile": "9876543210", ...}
  status      String      @default("pending")   // pending, mapped, inserted, skipped, error
  errorMsg    String?                           // "Missing phone number"
  leadId      String?                           // FK to created Lead (after successful insert)
  createdAt   DateTime    @default(now())

  @@index([importId])
}

model ImportTemplate {
  id            String   @id @default(cuid())
  name          String                       // "Meta Ads Import", "JustDial Format"
  sourceName    String                       // "Meta Ads"
  columnMapping Json                         // {"Full Name": "name", "Phone Number": "phone", ...}
  createdBy     String   @default("admin")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
